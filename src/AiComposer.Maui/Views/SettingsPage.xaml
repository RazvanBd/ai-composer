<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AiComposer.Maui.ViewModels"
             x:Class="AiComposer.Maui.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" MaximumWidthRequest="600">

            <Label Text="Settings"
                   FontSize="24"
                   FontAttributes="Bold" />

            <!-- Workspace section -->
            <Label Text="Workspace" FontSize="16" FontAttributes="Bold" Margin="0,8,0,0" />
            <Label Text="Workspace path" FontSize="12" TextColor="Gray" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0"
                       Placeholder="/path/to/artifacts"
                       Text="{Binding WorkspacePath}" />
                <Button Grid.Column="1"
                        Text="Browse"
                        Command="{Binding BrowseWorkspaceCommand}" />
            </Grid>

            <Label Text="Output path" FontSize="12" TextColor="Gray" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0"
                       Placeholder="/path/to/output"
                       Text="{Binding OutputPath}" />
                <Button Grid.Column="1"
                        Text="Browse"
                        Command="{Binding BrowseOutputCommand}" />
            </Grid>

            <!-- AI Configuration section -->
            <Label Text="AI Configuration" FontSize="16" FontAttributes="Bold" Margin="0,8,0,0" />
            <Label Text="Provider" FontSize="12" TextColor="Gray" />
            <Picker ItemsSource="{Binding Providers}"
                    SelectedItem="{Binding SelectedProvider}" />

            <Label Text="Model" FontSize="12" TextColor="Gray" />
            <Entry Placeholder="e.g. gpt-5, claude-sonnet"
                   Text="{Binding Model}" />

            <Label Text="API Key" FontSize="12" TextColor="Gray" />
            <Entry Placeholder="sk-..."
                   IsPassword="True"
                   Text="{Binding ApiKey}" />

            <!-- Run policies section -->
            <Label Text="Run Policies" FontSize="16" FontAttributes="Bold" Margin="0,8,0,0" />
            <Grid ColumnDefinitions="*,Auto" Padding="0,4,0,0">
                <Label Grid.Column="0"
                       Text="Auto-approve"
                       VerticalOptions="Center" />
                <Switch Grid.Column="1"
                        IsToggled="{Binding AutoApprove}" />
            </Grid>

            <Label Text="{Binding TimeoutMinutes, StringFormat='Timeout per run: {0} minute(s)'}"
                   FontSize="12"
                   TextColor="Gray" />
            <Stepper Minimum="1"
                     Maximum="180"
                     Increment="1"
                     Value="{Binding TimeoutMinutes}" />

            <Label Text="{Binding MaxRetries, StringFormat='Max retries: {0}'}"
                   FontSize="12"
                   TextColor="Gray" />
            <Stepper Minimum="0"
                     Maximum="10"
                     Increment="1"
                     Value="{Binding MaxRetries}" />

            <!-- Actions -->
            <HorizontalStackLayout Spacing="12" Margin="0,16,0,0">
                <Button Text="Save Settings"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        CornerRadius="8" />
                <Button Text="Reset to Defaults"
                        Command="{Binding ResetCommand}"
                        BackgroundColor="#6B7280"
                        TextColor="White"
                        CornerRadius="8" />
                <ActivityIndicator IsRunning="{Binding IsSaving}" IsVisible="{Binding IsSaving}" />
            </HorizontalStackLayout>

            <Label Text="{Binding SaveConfirmationMessage}"
                   TextColor="#15803D"
                   FontSize="12"
                   IsVisible="{Binding HasSavedConfirmation}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
