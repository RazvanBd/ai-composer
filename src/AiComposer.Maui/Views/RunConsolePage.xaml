<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AiComposer.Maui.ViewModels"
             xmlns:models="clr-namespace:AiComposer.Maui.Models"
             xmlns:converters="clr-namespace:AiComposer.Maui.Converters"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="AiComposer.Maui.Views.RunConsolePage"
             x:DataType="vm:RunConsoleViewModel"
             Title="Run Console">

    <ContentPage.Resources>
        <converters:RunStatusToStringConverter x:Key="RunStatusToStringConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Header: ticket title + run status -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="12,10" BackgroundColor="#1E3A5F">
            <Label Grid.Column="0"
                   Text="{Binding SelectedTicketTitle, TargetNullValue='No ticket selected'}"
                   FontSize="15"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center" />
            <Label Grid.Column="1"
                   Text="{Binding RunStatus, Converter={StaticResource RunStatusToStringConverter}}"
                   FontSize="12"
                   TextColor="#93C5FD"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Controls -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto,Auto" Padding="12,8" ColumnSpacing="8">
            <Entry Grid.Column="0"
                   Placeholder="Ticket ID (e.g. T-101)"
                   Text="{Binding TicketId}"
                   ClearButtonVisibility="WhileEditing" />
            <Button Grid.Column="1"
                    Text="▶ Start"
                    Command="{Binding StartRunCommand}"
                    BackgroundColor="#16A34A"
                    TextColor="White"
                    CornerRadius="6" />
            <Button Grid.Column="2"
                    Text="Run All Ready Tickets"
                    Command="{Binding RunAllReadyCommand}"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="6" />
            <Button Grid.Column="3"
                    Text="■ Stop"
                    Command="{Binding StopRunCommand}"
                    BackgroundColor="#DC2626"
                    TextColor="White"
                    CornerRadius="6" />
            <Button Grid.Column="4"
                    Text="Clear"
                    Command="{Binding ClearOutputCommand}"
                    BackgroundColor="#6B7280"
                    TextColor="White"
                    CornerRadius="6" />
        </Grid>

        <VerticalStackLayout Grid.Row="2" Padding="12,0,12,8" Spacing="2">
            <Label Text="{Binding BatchProgressText}" FontSize="12" TextColor="#1D4ED8" />
            <Label Text="{Binding BatchRunSummary}" FontSize="12" TextColor="#374151" />
        </VerticalStackLayout>

        <toolkit:TabView Grid.Row="3" Padding="12,0,12,8">
            <toolkit:TabViewItem Text="Logs">
                <CollectionView x:Name="LogsCollectionView"
                                ItemsSource="{Binding OutputLines}"
                                BackgroundColor="#1E1E1E">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Label Text="{Binding .}"
                                   FontFamily="Courier New"
                                   FontSize="12"
                                   TextColor="#D4D4D4"
                                   Padding="12,2" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </toolkit:TabViewItem>

            <toolkit:TabViewItem Text="Applied Files">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8" Padding="0,8,0,0">
                    <Label Grid.Row="0"
                           Text="{Binding AuditAppliedFilesCount, StringFormat='Files changed: {0}'}"
                           FontSize="12"
                           TextColor="Gray" />
                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding AppliedFiles}"
                                    SelectionMode="Single"
                                    SelectedItem="{Binding SelectedAppliedFile}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:AppliedFileItem">
                                <Grid Padding="8,6" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0"
                                           Text="{Binding RelativePath}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1"
                                           Text="{Binding ChangeKind}"
                                           FontSize="11"
                                           TextColor="White"
                                           BackgroundColor="#334155"
                                           Padding="8,2"
                                           VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Button Grid.Row="2"
                            Text="Open in Viewer"
                            Command="{Binding OpenInViewerCommand}"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            CornerRadius="6"
                            HorizontalOptions="Start" />
                </Grid>
            </toolkit:TabViewItem>

            <toolkit:TabViewItem Text="Audit">
                <VerticalStackLayout Padding="0,8,0,0" Spacing="8">
                    <Label Text="{Binding AuditTicket, StringFormat='Ticket: {0}'}" FontSize="12" />
                    <Label Text="{Binding AuditStartTimestamp, StringFormat='Start: {0}'}" FontSize="12" />
                    <Label Text="{Binding AuditEndTimestamp, StringFormat='End: {0}'}" FontSize="12" />
                    <Label Text="{Binding AuditDuration, StringFormat='Duration: {0}'}" FontSize="12" />
                    <Label Text="{Binding AuditFinalStatus, StringFormat='Final status: {0}'}" FontSize="12" />
                    <Label Text="{Binding AuditPromptSummary}" FontSize="12" />
                    <Label Text="{Binding AuditTokenSummary}" FontSize="12" />
                    <Label Text="{Binding AuditAppliedFilesCount, StringFormat='Applied files: {0}'}" FontSize="12" />
                </VerticalStackLayout>
            </toolkit:TabViewItem>
        </toolkit:TabView>

        <!-- Status bar -->
        <HorizontalStackLayout Grid.Row="4" Padding="12,6" Spacing="8">
            <ActivityIndicator IsRunning="{Binding IsRunning}" IsVisible="{Binding IsRunning}" />
            <Label Text="{Binding RunStatus, Converter={StaticResource RunStatusToStringConverter}}"
                   FontSize="12" TextColor="Gray" VerticalOptions="Center" />
        </HorizontalStackLayout>

    </Grid>

</ContentPage>
