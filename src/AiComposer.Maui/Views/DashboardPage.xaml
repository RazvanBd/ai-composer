<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AiComposer.Maui.ViewModels"
             x:Class="AiComposer.Maui.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label Text="AiComposer Dashboard"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="{Binding WorkspacePath}"
                   FontSize="14"
                   TextColor="Gray"
                   HorizontalOptions="Center" />

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center" />

            <!-- Artifact + ticket total counts -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="12">
                <Frame Grid.Column="0" BackgroundColor="#EFF6FF" CornerRadius="8" Padding="16">
                    <VerticalStackLayout>
                        <Label Text="Artifacts" FontSize="12" TextColor="Gray" />
                        <Label Text="{Binding ArtifactCount}" FontSize="32" FontAttributes="Bold" TextColor="#2563EB" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" BackgroundColor="#F0FDF4" CornerRadius="8" Padding="16">
                    <VerticalStackLayout>
                        <Label Text="Tickets" FontSize="12" TextColor="Gray" />
                        <Label Text="{Binding TicketCount}" FontSize="32" FontAttributes="Bold" TextColor="#16A34A" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Ticket status breakdown -->
            <Label Text="Ticket Status" FontSize="14" FontAttributes="Bold" Margin="0,4,0,0" />
            <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto" ColumnSpacing="8">
                <Frame Grid.Column="0" BackgroundColor="#EFF6FF" CornerRadius="8" Padding="10">
                    <VerticalStackLayout>
                        <Label Text="Ready" FontSize="11" TextColor="#2563EB" HorizontalOptions="Center" />
                        <Label Text="{Binding TicketsReady}" FontSize="24" FontAttributes="Bold"
                               TextColor="#2563EB" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" BackgroundColor="#FFFBEB" CornerRadius="8" Padding="10">
                    <VerticalStackLayout>
                        <Label Text="Running" FontSize="11" TextColor="#D97706" HorizontalOptions="Center" />
                        <Label Text="{Binding TicketsRunning}" FontSize="24" FontAttributes="Bold"
                               TextColor="#D97706" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="2" BackgroundColor="#F0FDF4" CornerRadius="8" Padding="10">
                    <VerticalStackLayout>
                        <Label Text="Done" FontSize="11" TextColor="#16A34A" HorizontalOptions="Center" />
                        <Label Text="{Binding TicketsDone}" FontSize="24" FontAttributes="Bold"
                               TextColor="#16A34A" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="3" BackgroundColor="#FEF2F2" CornerRadius="8" Padding="10">
                    <VerticalStackLayout>
                        <Label Text="Blocked" FontSize="11" TextColor="#DC2626" HorizontalOptions="Center" />
                        <Label Text="{Binding TicketsBlocked}" FontSize="24" FontAttributes="Bold"
                               TextColor="#DC2626" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Last run -->
            <Frame BackgroundColor="#F9FAFB" CornerRadius="8" Padding="16" Margin="0,4,0,0">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Last Run" FontSize="12" TextColor="Gray" />
                    <Label Text="{Binding LastRunSummary}" FontSize="14" FontAttributes="Bold" TextColor="#374151" />
                </VerticalStackLayout>
            </Frame>

            <!-- Action buttons -->
            <Button Text="Open Workspace"
                    Command="{Binding OpenWorkspaceCommand}"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="8"
                    Margin="0,8,0,0" />

            <Button Text="Validate Artifacts"
                    Command="{Binding ValidateArtifactsCommand}"
                    BackgroundColor="#7C3AED"
                    TextColor="White"
                    CornerRadius="8" />

            <Button Text="Refresh"
                    Command="{Binding RefreshCommand}"
                    BackgroundColor="#6B7280"
                    TextColor="White"
                    CornerRadius="8" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
