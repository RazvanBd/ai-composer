<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AiComposer.Maui.ViewModels"
             xmlns:models="clr-namespace:AiComposer.Maui.Models"
             x:Class="AiComposer.Maui.Views.ArtifactsExplorerPage"
             x:DataType="vm:ArtifactsExplorerViewModel"
             Title="Artifacts Explorer">

    <Grid ColumnDefinitions="300,*" RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <HorizontalStackLayout Grid.Row="0" Grid.ColumnSpan="2" Padding="12,8" Spacing="8">
            <Button Text="Load Artifacts"
                    Command="{Binding LoadArtifactsCommand}"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="6" />
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
        </HorizontalStackLayout>

        <!-- Artifact list -->
        <CollectionView Grid.Row="1" Grid.Column="0"
                        ItemsSource="{Binding Artifacts}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedArtifact}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ArtifactItem">
                    <Grid Padding="12,8" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="{Binding Type}" FontSize="10"
                               TextColor="White" BackgroundColor="#6B7280"
                               Padding="4,2" />
                        <Label Grid.Column="1" Text="{Binding Title}" FontSize="14"
                               LineBreakMode="TailTruncation" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Content preview -->
        <ScrollView Grid.Row="1" Grid.Column="1" Padding="12">
            <Editor Text="{Binding SelectedContent}"
                    IsReadOnly="True"
                    FontFamily="Courier New"
                    FontSize="12"
                    AutoSize="TextChanges"
                    Placeholder="Select an artifact to preview its content." />
        </ScrollView>

    </Grid>

</ContentPage>
