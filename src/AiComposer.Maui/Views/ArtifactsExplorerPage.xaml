<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AiComposer.Maui.ViewModels"
             xmlns:models="clr-namespace:AiComposer.Maui.Models"
             x:Class="AiComposer.Maui.Views.ArtifactsExplorerPage"
             x:DataType="vm:ArtifactsExplorerViewModel"
             Title="Artifacts Explorer">

    <Grid ColumnDefinitions="300,*" RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <HorizontalStackLayout Grid.Row="0" Grid.ColumnSpan="2" Padding="12,8" Spacing="8">
            <Button Text="Load Artifacts"
                    Command="{Binding LoadArtifactsCommand}"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="6" />
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
        </HorizontalStackLayout>

        <!-- Grouped artifact list -->
        <CollectionView Grid.Row="1" Grid.Column="0"
                        ItemsSource="{Binding GroupedArtifacts}"
                        IsGrouped="True"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedArtifact}">

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="models:ArtifactGroup">
                    <Label Text="{Binding GroupTitle}"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#374151"
                           BackgroundColor="#F3F4F6"
                           Padding="12,6" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ArtifactItem">
                    <Grid Padding="12,8" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="{Binding Title}"
                               FontSize="13"
                               LineBreakMode="TailTruncation" />
                        <Label Grid.Column="1"
                               Text="{Binding ValidationStatus}"
                               FontSize="10"
                               TextColor="White"
                               Padding="4,2"
                               VerticalOptions="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding ValidationStatus}" Value="Valid">
                                    <Setter Property="BackgroundColor" Value="#16A34A" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding ValidationStatus}" Value="Invalid">
                                    <Setter Property="BackgroundColor" Value="#DC2626" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding ValidationStatus}" Value="Unknown">
                                    <Setter Property="BackgroundColor" Value="#6B7280" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Content preview -->
        <ScrollView Grid.Row="1" Grid.Column="1" Padding="12">
            <Editor Text="{Binding SelectedContent}"
                    IsReadOnly="True"
                    FontFamily="Courier New"
                    FontSize="12"
                    AutoSize="TextChanges"
                    Placeholder="Select an artifact to preview its content." />
        </ScrollView>

    </Grid>

</ContentPage>
